default_platform(:ios)

platform :ios do
  desc "One-time setup: Register app on Apple Developer Portal and App Store Connect"
  lane :setup do
    # Note: produce uses username auth, not API key
    # Set FASTLANE_USER env var or login interactively
    produce(
      app_identifier: "com.teleprompter1900.app",
      app_name: "Teleprompter",
      language: "English",
      app_version: "1.0",
      sku: "teleprompter001",
      team_id: "A8DGL4UP7K",
      username: "submitter2godalone@yahoo.com"
    )
  end

  desc "Setup certificates and profiles using match"
  lane :certificates do
    api_key = app_store_connect_api_key(
      key_id: "RMF4KW68PC",
      issuer_id: "69a6de78-5e04-47e3-e053-5b8c7c11a4d1",
      key_filepath: "./fastlane/AuthKey_RMF4KW68PC.p8",
      duration: 1200,
      in_house: false
    )

    match(
      type: "appstore",
      app_identifier: "com.teleprompter1900.app",
      team_id: "A8DGL4UP7K",
      api_key: api_key
    )
  end

  desc "Build and upload to App Store Connect (TestFlight)"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: "RMF4KW68PC",
      issuer_id: "69a6de78-5e04-47e3-e053-5b8c7c11a4d1",
      key_filepath: "./fastlane/AuthKey_RMF4KW68PC.p8",
      duration: 1200,
      in_house: false
    )

    # Get certificates and profiles
    match(
      type: "appstore",
      app_identifier: "com.teleprompter1900.app",
      team_id: "A8DGL4UP7K",
      api_key: api_key,
      readonly: true
    )

    # Increment build number
    increment_build_number(
      xcodeproj: "TeleprompterApp.xcodeproj"
    )

    # Build the app
    build_app(
      scheme: "TeleprompterApp",
      export_method: "app-store",
      clean: true,
      output_directory: "./build",
      output_name: "TeleprompterApp.ipa"
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Build only (no upload)"
  lane :build do
    build_app(
      scheme: "TeleprompterApp",
      export_method: "app-store",
      clean: true,
      output_directory: "./build",
      output_name: "TeleprompterApp.ipa"
    )
  end

  desc "Upload metadata and screenshots to App Store Connect"
  lane :metadata do
    api_key = app_store_connect_api_key(
      key_id: "RMF4KW68PC",
      issuer_id: "69a6de78-5e04-47e3-e053-5b8c7c11a4d1",
      key_filepath: "./fastlane/AuthKey_RMF4KW68PC.p8",
      duration: 1200,
      in_house: false
    )

    deliver(
      api_key: api_key,
      app_identifier: "com.teleprompter1900.app",
      skip_binary_upload: true,
      skip_screenshots: false,
      force: true,
      skip_app_version_update: false,
      submit_for_review: false,
      automatic_release: false
    )
  end
end

